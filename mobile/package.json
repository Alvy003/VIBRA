{
  "name": "mobile",
  "main": "index.js",
  "version": "1.0.0",
  "scripts": {
    "start": "npx expo start",
    "dev": "cross-env APP_VARIANT=development npx expo start",
    "prod": "cross-env APP_VARIANT=production npx expo start",
    "android:dev": "cross-env APP_VARIANT=development node scripts/fix-android.js && npx expo run:android",
    "android:prod": "cross-env APP_VARIANT=production node scripts/fix-android.js && npx expo run:android",
    "android:release": "cross-env APP_VARIANT=production node scripts/fix-android.js && npx expo run:android --variant release",
    "ios:dev": "cross-env APP_VARIANT=development npx expo run:ios",
    "ios:prod": "cross-env APP_VARIANT=production npx expo run:ios",
    "prebuild": "npx expo prebuild",
    "prebuild:clean": "npx expo prebuild --clean",
    "android:dev:clean": "cross-env APP_VARIANT=development npx expo prebuild --clean && npm run android:dev",
    "android:prod:clean": "cross-env APP_VARIANT=production npx expo prebuild --clean && npm run android:prod",
    "android:release:clean": "cross-env APP_VARIANT=production npx expo prebuild --clean && npm run android:release",
    "postinstall": "patch-package",
    "android": "npx expo run:android",
    "ios": "npx expo run:ios"
  },
  "dependencies": {
    "@clerk/clerk-expo": "^2.19.26",
    "@expo/vector-icons": "^15.0.3",
    "@gorhom/bottom-sheet": "^5.2.8",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/slider": "5.0.1",
    "@react-native-masked-view/masked-view": "0.3.2",
    "@react-navigation/native": "^7.1.8",
    "@sentry/react-native": "~7.2.0",
    "@shopify/flash-list": "2.0.2",
    "axios": "^1.13.5",
    "buffer": "^6.0.3",
    "expo": "~54.0.33",
    "expo-audio": "~1.1.1",
    "expo-auth-session": "~7.0.10",
    "expo-av": "~16.0.8",
    "expo-blur": "~15.0.8",
    "expo-constants": "~18.0.13",
    "expo-dev-client": "~6.0.20",
    "expo-device": "~8.0.10",
    "expo-file-system": "~19.0.21",
    "expo-font": "~14.0.11",
    "expo-haptics": "~15.0.8",
    "expo-image": "~3.0.11",
    "expo-intent-launcher": "~13.0.8",
    "expo-linear-gradient": "~15.0.8",
    "expo-linking": "~8.0.11",
    "expo-router": "~6.0.23",
    "expo-secure-store": "~15.0.8",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-web-browser": "~15.0.10",
    "fastestsmallesttextencoderdecoder": "^1.0.22",
    "lucide-react-native": "^0.575.0",
    "nativewind": "^4.2.2",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-bluetooth-state-manager": "^2.0.4",
    "react-native-draggable-flatlist": "^4.0.3",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-get-random-values": "^2.0.0",
    "react-native-image-colors": "^2.5.1",
    "react-native-mmkv": "^3.3.3",
    "react-native-reanimated": "^4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-text-ticker": "^1.15.0",
    "react-native-track-player": "^4.1.2",
    "react-native-url-polyfill": "^3.0.0",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "^0.5.1",
    "tailwindcss": "^3.4.19",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@types/react": "~19.1.0",
    "cross-env": "^10.1.0",
    "expo-module-scripts": "^55.0.2",
    "patch-package": "^8.0.1",
    "react-test-renderer": "19.1.0",
    "typescript": "~5.9.2"
  },
  "private": true
}
